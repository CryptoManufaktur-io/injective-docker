COMPOSE_FILE=injective.yml #:ext-network.yml # uncomment to use external network
MONIKER=injective-node-docker
NETWORK=injective-1


INJECTIVE_NODE_VERSION=v1.15.0
# sourced from here https://github.com/InjectiveLabs/injective-chain-releases/releases
BINARY_VERSION=v1.15.0-1748457819

MIN_GAS_PRICE=160000000inj
EXTRA_FLAGS=

# Binary base download URL
DOWNLOAD_BASE_URL="https://github.com/InjectiveLabs/injective-chain-releases/releases/download"

STATE_SYNC_URL="https://injective-rpc.polkachu.com:443"
# set if the node is having trouble connecting to peers
# Can find peers https://www.polkachu.com/live_peers/injective
PEERS="4abc9ca0ad53a42fe51381635284f678b6edcb8a@65.109.56.166:14356"
SEEDS="ade4d8bc8cbe014af6ebdf3cb7b1e9ad36f412c0@seeds.polkachu.com:14356"
# Cosmovisor variables
DAEMON_NAME=injectived
DAEMON_HOME=~/.injectived

# Use latest from https://www.polkachu.com/tendermint_snapshots/injective
SNAPSHOT="https://snapshots.polkachu.com/snapshots/injective/injective_125999014.tar.lz4"

CL_GRPC_PORT=9090
CL_P2P_PORT=2121
CL_RPC_PORT=26657
RPC_PORT=8545
WS_PORT=8546

# Secure web proxy - advanced use, please see instructions
DOMAIN=example.com
RPC_HOST=injective
RPC_LB=injective-lb
WS_HOST=injectivews
WS_LB=injectivews-lb

# info, warn, error, trace
LOG_LEVEL=info

# External Docker network if using ext-network.yml
DOCKER_EXT_NETWORK=traefik_default

# You can pin the version of injective-docker here
SCRIPT_TAG=

# Used by injectived update - please do not adjust
ENV_VERSION=2
